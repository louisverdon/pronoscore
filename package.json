{
  "name": "pronoscore-monorepo",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build": "turbo build",
    "build:dev": "turbo build:dev",
    "build:prod": "turbo build:prod",
    "deploy:dev": "npm run build:dev --workspace=apps/web && firebase use dev && firebase deploy",
    "deploy:prod": "npm run build:prod --workspace=apps/web && firebase use production && firebase deploy",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.0.0"
  }
}
