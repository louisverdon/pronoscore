{
  "name": "pronoscore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "launch_test": "node launch_test",
    "edit_test": "node edit_test",
    "dev": "next dev",
    "build": "next build",
    "build:dev": "env-cmd -f .env.local next build",
    "build:prod": "env-cmd -f .env.production next build",
    "deploy:dev": "npm run build:dev && firebase use dev && firebase deploy",
    "deploy:prod": "npm run build:prod && firebase use production && firebase deploy",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "firebase": "^11.0.2",
    "next": "15.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "env-cmd": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  }
}