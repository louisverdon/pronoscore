rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: read own document + others' for classement; write only own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Matches: read-only for all authenticated users
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Predictions: users can create/update only their own
    match /predictions/{predictionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Leagues: create if auth, read if auth
    match /leagues/{leagueId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // League members: add self, read if auth, delete own membership (quitter une ligue)
    // ou suppression par le créateur de la ligue
    match /leagueMembers/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null
        && (
          // l'utilisateur quitte lui-même la ligue
          resource.data.userId == request.auth.uid
          // ou le créateur de la ligue exclut un membre
          || get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)).data.createdBy == request.auth.uid
        );
    }
  }
}
